# ==============================================================================
# Production Backend Environment Variables Template (.env.backend.prod.example)
# Copy this file to `.env.backend.prod` and configure actual production values.
# ==============================================================================

# Core Configuration
ENV=production
PROJECT_NAME="Tender Intelligence Platform"
SECRET_KEY=prod_secure_cryptographic_signing_key_generate_yours_here
LOG_LEVEL=info

# PostgreSQL Connection (Use postgres service name in docker-compose)
DATABASE_URL=postgresql+asyncpg://app_user:prod_secure_password_db@postgres:5432/tender_intel

# Vector Search (Qdrant service name in docker-compose)
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=prod_secure_qdrant_api_key_here

# LLM Provider Configuration
GEMINI_API_KEY=prod_secure_gemini_api_key_obtained_from_ai_studio

# Observability & Metrics (Configure Sentry DSN and OpenTelemetry endpoint)
SENTRY_DSN=https://your-dsn-key@o0.ingest.sentry.io/project-id
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus_multiproc_dir
